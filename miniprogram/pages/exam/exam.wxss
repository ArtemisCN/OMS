.page { padding: 20rpx 30rpx; min-height: 100vh; background: #f5f6fa; }
.page-header { margin-bottom: 30rpx; }
.page-title { font-size: 40rpx; font-weight: 700; color: #1e293b; display: block; }
.page-desc { font-size: 26rpx; color: #94a3b8; margin-top: 8rpx; display: block; }

.section-title { display:flex; justify-content:space-between; font-size:28rpx; font-weight:600; color:#64748b; margin-bottom:16rpx; }
.toggle-icon { font-size:24rpx; color:#94a3b8; }

.loading-wrap { display: flex; flex-direction: column; align-items: center; padding: 100rpx 0; color: #94a3b8; font-size: 28rpx; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 6rpx solid #e2e8f0; border-top-color: #6366f1; border-radius: 50%; animation: spin .8s linear infinite; margin-bottom: 20rpx; }
@keyframes spin { to { transform: rotate(360deg); } }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; color: #94a3b8; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }

.exam-list { display: flex; flex-direction: column; gap: 16rpx; }
.exam-card { background: #fff; border-radius: 16rpx; padding: 26rpx 30rpx; display: flex; align-items: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.04); }
.exam-card.history { opacity:.8; }
.exam-card-body { flex: 1; }
.exam-title { font-size: 30rpx; font-weight: 600; color: #1e293b; }
.exam-meta { font-size: 24rpx; color: #94a3b8; margin-top: 6rpx; }
.exam-arrow { color: #cbd5e1; font-size: 32rpx; margin-left: 16rpx; }
