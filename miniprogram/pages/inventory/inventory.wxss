.page { min-height: 100vh; background: #f5f6fa; padding-bottom: 40rpx; }

.header {
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  color: #fff;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky; top: 0; z-index: 10;
}
.header-title { font-size: 36rpx; font-weight: 700; }
.header-btn { font-size: 26rpx; color: #fff; }

.stat-bar {
  display: flex; margin: 28rpx; gap: 16rpx;
}
.stat-item {
  flex: 1; background: #fff; border-radius: 20rpx;
  padding: 24rpx 12rpx; text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.stat-num { display: block; font-size: 40rpx; font-weight: 800; color: #4338ca; line-height: 1.1; }
.stat-label { display: block; font-size: 24rpx; color: #64748b; margin-top: 8rpx; }

.task-list { padding: 0 28rpx; }
.task-card {
  background: #fff; border-radius: 20rpx; padding: 28rpx;
  margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.task-card:active { transform: scale(0.98); }

.task-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.task-name { font-size: 30rpx; font-weight: 600; color: #0f172a; }
.task-status-wrap {
  font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 30rpx; font-weight: 500;
  display: flex; align-items: center; justify-content: center;
  min-height: 44rpx; box-sizing: border-box;
}
.task-status-wrap.pending { background: #fffbeb; color: #b45309; }
.task-status-wrap.done { background: #ecfdf5; color: #059669; }
.task-status-wrap.empty { background: #f1f5f9; color: #94a3b8; }

.task-no { font-size: 22rpx; color: #94a3b8; margin-bottom: 16rpx; display: block; }

.task-stats { display: flex; gap: 8rpx; margin: 16rpx 0; }
.ts-item { flex: 1; text-align: center; }
.ts-num { display: block; font-size: 32rpx; font-weight: 700; color: #0f172a; }
.ts-num.primary { color: #4f46e5; }
.ts-num.success { color: #059669; }
.ts-num.warning { color: #f59e0b; }
.ts-num.purple { color: #7c3aed; }
.ts-label { display: block; font-size: 20rpx; color: #94a3b8; margin-top: 4rpx; }

.task-meta { font-size: 22rpx; color: #94a3b8; }

.empty { text-align: center; padding: 160rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: #64748b; margin-top: 12rpx; display: block; }
.empty-hint { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; display: block; }

.loading-wrap { text-align: center; padding: 200rpx 0; }
.loading-text { font-size: 28rpx; color: #94a3b8; }

/* 新建弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.modal-content {
  background: #fff; border-radius: 24rpx; padding: 40rpx;
  width: 600rpx; max-width: 85%;
}
.modal-title { font-size: 32rpx; font-weight: 600; color: #0f172a; margin-bottom: 24rpx; }
.modal-input {
  background: #f1f5f9; border-radius: 16rpx; padding: 24rpx;
  font-size: 28rpx; width: 100%; box-sizing: border-box;
}
.modal-btns { display: flex; gap: 20rpx; margin-top: 32rpx; justify-content: flex-end; }
.modal-btn { font-size: 28rpx; padding: 16rpx 36rpx; border-radius: 16rpx; font-weight: 500; }
.modal-btn.cancel { background: #f1f5f9; color: #64748b; }
.modal-btn.confirm { background: #4f46e5; color: #fff; }
