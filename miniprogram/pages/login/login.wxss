.login-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #4338ca 0%, #6366f1 50%, #818cf8 100%);
}

.login-box {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.12);
}

.logo {
  text-align: center;
  margin-bottom: 50rpx;
}

.logo-icon {
  font-size: 64rpx;
  display: block;
}

.logo-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  margin-top: 12rpx;
  display: block;
}

.logo-subtitle {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  display: block;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input {
  display: block;
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #0f172a;
  background: #f8fafc;
  box-sizing: border-box;
  transition: border-color .2s, box-shadow .2s, background .2s;
}

.input:focus {
  border-color: #4f46e5;
  box-shadow: 0 0 0 3rpx rgba(79,70,229,0.12);
  background: #fff;
}

.btn-login {
  width: 100%;
  height: 88rpx;
  background: #4f46e5;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 88rpx;
}

.btn-login:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-login[disabled] {
  opacity: 0.6;
}
