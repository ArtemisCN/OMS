.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 100rpx;
}

/* 顶部栏 */
.header {
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  color: #fff;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
}

.header-user {
  font-size: 26rpx;
  opacity: 0.85;
  margin-left: 16rpx;
}

.btn-logout {
  background: none;
  color: rgba(255,255,255,0.6);
  border: 1rpx solid rgba(255,255,255,0.2);
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  line-height: 1.6;
}

.btn-more {
  font-size: 40rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 700;
  letter-spacing: 2rpx;
  padding: 0 8rpx;
  line-height: 1;
}

/* 顶栏小加号 */
.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.fab-mini {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255,255,255,0.35);
}
.fab-mini:active { background: rgba(255,255,255,0.35); }
.fab-mini.inv-btn { background: rgba(16,185,129,0.3); border-color: rgba(16,185,129,0.5); }
.fab-mini-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

/* 微信绑定提示条 */
.wx-bind-tip {
  background: #eef2ff;
  color: #4f46e5;
  text-align: center;
  padding: 14rpx;
  font-size: 26rpx;
  border-bottom: 2rpx solid #dde4ff;
}

/* 统计条 */
.stat-row {
  display: flex;
  margin: 28rpx 28rpx;
  gap: 20rpx;
}

.stat-item {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  transition: all .25s cubic-bezier(0.4,0,0.2,1);
}
.stat-item:active {
  transform: scale(0.96);
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}
.stat-item.active {
  background: #eef2ff;
  box-shadow: 0 4rpx 16rpx rgba(79,70,229,0.15);
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #4338ca;
  line-height: 1.1;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 10rpx;
  line-height: 1.3;
}

/* 加载中 - 全屏启动画面 */
.loading-wrap {
  text-align: center;
  padding: 120rpx 0;
}

.loading-icon {
  display: inline-block;
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8ecf1;
  border-top-color: #4f46e5;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  display: block;
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 16rpx;
}

/* 首屏静态加载（无动画，快速） */
.splash-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
}

.splash-loading-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.splash-loading-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  display: block;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
  margin-top: 16rpx;
  display: block;
}

/* 工单列表 */
.order-list {
  padding: 0 28rpx;
  will-change: transform;
  transform: translateZ(0);
}

.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  transition: all .2s cubic-bezier(0.4,0,0.2,1);
  will-change: transform;
  transform: translateZ(0);
}
.order-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.order-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 16rpx;
}

.order-title-row {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 8rpx;
}
.priority-dot.emergency { background: #ef4444; }
.priority-dot.urgent { background: #f59e0b; }
.priority-dot.normal { background: #22c55e; }

.inspection-badge {
  font-size: 20rpx;
  margin-right: 4rpx;
}

/* 状态标签 */
.badge {
  display: inline-block;
  padding: 6rpx 22rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.badge-pending {
  background: #fffbeb;
  color: #b45309;
}

.badge-progress {
  background: #eef2ff;
  color: #4f46e5;
}

.badge-done {
  background: #ecfdf5;
  color: #059669;
}

/* 元数据 */
.order-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #64748b;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #94a3b8;
  padding-top: 16rpx;
  border-top: 2rpx solid #f1f5f9;
}

.btn-group-solve {
  display: flex;
  gap: 6rpx;
  flex: 1;
  max-width: 260rpx;
}

.btn-go-solve {
  background: #4f46e5;
  color: #fff;
  border: none;
  font-size: 22rpx;
  padding: 4rpx 0;
  border-radius: 30rpx;
  line-height: 50rpx;
  font-weight: 500;
  flex: 1;
  text-align: center;
  min-width: 90rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.08);
  transition: opacity .2s;
}
.btn-go-solve:active {
  opacity: 0.8;
}

.btn-quick-solve {
  background: #059669;
  color: #fff;
  border: none;
  font-size: 22rpx;
  padding: 4rpx 0;
  border-radius: 30rpx;
  line-height: 50rpx;
  flex: 1;
  text-align: center;
  font-weight: 500;
  min-width: 90rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.08);
}

/* 今日总结栏 */
.summary-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f0f4ff;
  border: none;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin: 0 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.summary-info {
  font-size: 26rpx;
  color: #4a5568;
}
.btn-summary {
  background: #4f46e5;
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 36rpx;
  font-weight: 500;
}
.btn-summary:active { opacity: 0.8; }

/* ===== 浮动发布按钮 ===== */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(79,70,229,0.4);
  z-index: 100;
  transition: transform .15s, box-shadow .2s;
}
.fab:active { transform:scale(0.92);box-shadow:0 4rpx 16rpx rgba(79,70,229,0.35); }
.fab-icon {
  font-size: 52rpx;
  color: #fff;
  font-weight: 200;
  line-height: 1;
}
