.page { min-height: 100vh; background: #f5f6fa; }

.header {
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  color: #fff; padding: 24rpx 30rpx;
  display: flex; align-items: center; justify-content: space-between;
  position: sticky; top: 0; z-index: 10;
}
.header-title { font-size: 32rpx; font-weight: 700; }
.header-sub { font-size: 22rpx; opacity: 0.7; margin-top: 4rpx; display: block; }
.header-back { font-size: 26rpx; padding: 8rpx 16rpx; background: rgba(255,255,255,0.2); border-radius: 12rpx; }

/* 统计 */
.stats-row {
  display: flex; margin: 20rpx 24rpx; gap: 10rpx;
}
.stats-item { flex: 1; background: #fff; border-radius: 16rpx; padding: 16rpx 8rpx; text-align: center; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05); }
.s-num { display: block; font-size: 34rpx; font-weight: 800; color: #0f172a; }
.s-num.primary { color: #4f46e5; }
.s-num.success { color: #059669; }
.s-num.warning { color: #f59e0b; }
.s-num.purple { color: #7c3aed; }
.s-label { display: block; font-size: 20rpx; color: #94a3b8; margin-top: 4rpx; }

.content { padding: 0 24rpx; }

.section-title { font-size: 28rpx; font-weight: 600; color: #0f172a; margin: 24rpx 0 16rpx; display: block; }
.section { margin-bottom: 24rpx; }

/* 楼区网格 */
.building-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.building-card {
  background: #fff; border-radius: 20rpx; padding: 28rpx 20rpx;
  text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.building-card:active { transform: scale(0.96); }
.b-name { font-size: 30rpx; font-weight: 600; color: #0f172a; display: block; }
.b-count { font-size: 22rpx; color: #94a3b8; margin-top: 8rpx; display: block; }

/* 楼层网格 */
.floor-grid { margin-top: 8rpx; }
.floor-item {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  margin-bottom: 12rpx; display: flex; justify-content: space-between; align-items: center;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.floor-item:active { background: #eef2ff; }
.floor-name { font-size: 28rpx; font-weight: 600; color: #0f172a; display: block; }
.floor-hint { font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; display: block; }
.floor-count { font-size: 26rpx; color: #94a3b8; font-weight: 600; }
.floor-count.has { color: #4f46e5; }

/* 楼层详情 */
.floor-detail-header { margin: 24rpx 0 16rpx; text-align: center; }
.fd-building { display:block; font-size:24rpx; color:#94a3b8; }
.fd-floor { display:block; font-size:40rpx; font-weight:700; color:#0f172a; margin-top:4rpx; }
.floor-stats { margin:16rpx 0 !important; }
.scan-area-sm {
  background:#fff; border-radius:20rpx; padding:32rpx; margin-bottom:16rpx;
  display:flex; align-items:center; gap:20rpx; box-shadow:0 2rpx 8rpx rgba(0,0,0,0.06);
}
.scan-area-sm:active { background:#eef2ff; }
.sas-icon { font-size:56rpx; }
.sas-text { flex:1; }
.sas-title { display:block; font-size:30rpx; font-weight:600; color:#0f172a; }
.sas-sub { display:block; font-size:24rpx; color:#94a3b8; margin-top:4rpx; }
.scan-actions-sm { margin-top:8rpx; }
.scan-btn-sm {
  background:#fff; border-radius:16rpx; padding:24rpx; margin-bottom:12rpx;
  box-shadow:0 2rpx 8rpx rgba(0,0,0,0.06); text-align:center;
}
.scan-btn-sm:active { background:#f1f5f9; }

/* 扫码界面 */
.scan-mode { padding: 40rpx 24rpx; text-align: center; }
.scan-header { margin-bottom: 40rpx; }
.scan-building { font-size: 34rpx; font-weight: 700; color: #0f172a; display: block; }
.scan-hint { font-size: 26rpx; color: #94a3b8; margin-top: 8rpx; display: block; }

.scan-area {
  width: 400rpx; height: 400rpx; margin: 0 auto;
  background: #fff; border-radius: 40rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(79,70,229,0.15);
  border: 4rpx dashed #4f46e5;
}
.scan-area:active { transform: scale(0.95); }
.scan-icon { font-size: 100rpx; display: block; margin-bottom: 16rpx; }
.scan-text { font-size: 32rpx; font-weight: 600; color: #4f46e5; }
.scan-sub { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }

.scan-actions { margin-top: 40rpx; }
.scan-btn {
  background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.scan-btn:active { background: #f1f5f9; }
.scan-btn.secondary { background: #f1f5f9; }

/* 弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45); z-index: 1000;
  display: flex; align-items: flex-end; justify-content: center;
}
.asset-modal {
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh; width: 100%; padding: 32rpx;
}
.asset-scroll { max-height: 75vh; }

.asset-header { margin-bottom: 24rpx; }
.asset-title { font-size: 30rpx; font-weight: 700; color: #0f172a; display: block; }
.asset-code { font-size: 24rpx; color: #64748b; margin-top: 6rpx; display: block; }

.asset-info-grid { background: #f8fafc; border-radius: 16rpx; padding: 16rpx; }
.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f1f5f9; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #64748b; }
.info-value { font-size: 26rpx; color: #0f172a; font-weight: 500; text-align: right; flex: 1; margin-left: 16rpx; }

/* 编辑模式 */
.edit-section { margin-top: 20rpx; }
.edit-title { font-size: 26rpx; font-weight: 600; color: #f59e0b; margin-bottom: 12rpx; display: block; }
.edit-field { margin-bottom: 12rpx; }
.edit-label { font-size: 24rpx; color: #64748b; margin-bottom: 4rpx; display: block; }
.edit-input {
  background: #f1f5f9; border-radius: 12rpx; padding: 16rpx;
  font-size: 26rpx; width: 100%; box-sizing: border-box;
}

/* 结果选择 */
.result-section { margin-top: 24rpx; }
.result-title { font-size: 26rpx; font-weight: 600; color: #0f172a; margin-bottom: 12rpx; display: block; }
.result-options { display: flex; gap: 16rpx; }
.result-option {
  flex: 1; text-align: center; padding: 20rpx; border-radius: 16rpx;
  border: 2rpx solid #e5e7eb; font-size: 26rpx;
}
.result-option:active { border-color: #4f46e5; }
.result-option.active.ok { border-color: #059669; background: #ecfdf5; color: #059669; }
.result-option.active.issue { border-color: #f59e0b; background: #fffbeb; color: #92400e; }
.ro-icon { display: block; font-size: 36rpx; margin-bottom: 4rpx; }

/* 备注 */
.notes-section { margin-top: 16rpx; }
.notes-input {
  background: #f1f5f9; border-radius: 12rpx; padding: 16rpx;
  font-size: 26rpx; width: 100%; min-height: 120rpx; box-sizing: border-box;
}

/* 操作按钮 */
.action-btns { margin-top: 24rpx; display: flex; flex-direction: column; gap: 12rpx; }
.action-btn {
  text-align: center; padding: 22rpx; border-radius: 16rpx; font-size: 28rpx; font-weight: 600;
}
.action-btn.primary { background: #4f46e5; color: #fff; }
.action-btn.primary:active { opacity: 0.85; }
.action-btn.secondary { background: #fef3c7; color: #92400e; }
.action-btn.cancel { background: #f1f5f9; color: #64748b; }

/* 已盘明细 */
.item-card {
  background: #fff; border-radius: 14rpx; padding: 20rpx;
  margin-bottom: 12rpx; box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}
.item-top { display: flex; justify-content: space-between; align-items: center; }
.item-code { font-size: 26rpx; font-weight: 600; color: #0f172a; }
.item-result { font-size: 20rpx; padding: 2rpx 16rpx; border-radius: 999px; }
.item-result.normal { background: #ecfdf5; color: #059669; }
.item-result.issue { background: #fffbeb; color: #92400e; }
.item-result.new { background: #eef2ff; color: #4338ca; }
.item-info { font-size: 24rpx; color: #64748b; margin-top: 6rpx; display: block; }
.item-time { font-size: 22rpx; color: #94a3b8; display: block; }

.empty-section { text-align: center; padding: 80rpx 0; color: #94a3b8; font-size: 26rpx; }

/* 选中楼层操作区 */
.selected-floor-bar {
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  border-radius: 20rpx; padding: 28rpx; margin: 24rpx 0 16rpx;
  display: flex; flex-direction: column; gap: 16rpx;
}
.sfb-info { text-align: center; }
.sfb-floor { display: block; font-size: 34rpx; font-weight: 700; color: #fff; }
.sfb-stats { display: block; font-size: 24rpx; color: rgba(255,255,255,0.75); margin-top: 4rpx; }
.sfb-actions { display: flex; gap: 12rpx; }
.sfb-btn {
  flex:1; text-align:center; padding:18rpx; border-radius:14rpx;
  font-size:26rpx; font-weight:600; background:rgba(255,255,255,0.2); color:#fff;
}
.sfb-btn:active { opacity:0.8; }
.sfb-btn.primary { background:#fff; color:#4f46e5; }
.sfb-btn.primary:active { background:#eef2ff; }
