.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* ===== 顶部大输入框 ===== */
.hero {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(79,70,229,0.08);
}
.hero-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}
.hero-input-wrap {
  flex: 1;
}
.hero-input {
  width: 100%;
  height: 60rpx;
  border: none;
  background: transparent;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  padding: 0;
}
.hero-holder {
  color: #94a3b8;
  font-size: 28rpx;
  font-weight: 400;
}

/* ===== 解析预览 ===== */
.preview {
  background: #eef2ff;
  border: 2rpx solid #d0d9f0;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.preview-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 6rpx 0;
}
.preview-label {
  font-size: 24rpx;
  color: #4f46e5;
  font-weight: 600;
  background: #fff;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.preview-val {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 500;
}

/* ===== 卡片区块 ===== */
.sec {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
}
.sec-hd {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 30rpx 0;
}
.sec-icon { font-size: 28rpx; }
.sec-t {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}
.sec-bd {
  padding: 20rpx 30rpx 28rpx;
}
.sec-sub {
  padding: 0 30rpx 20rpx;
}
.sec-sub-t {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

/* ===== 横向 chip 滚动 ===== */
.chip-scroll {
  white-space: nowrap;
  padding: 0 30rpx 20rpx;
}
.chip-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: nowrap;
}
.chip {
  display: inline-flex;
  align-items: center;
  height: 60rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #475569;
  background: #f1f5f9;
  border-radius: 30rpx;
  font-weight: 500;
  flex-shrink: 0;
  transition: all .2s;
}
.chip:active {
  opacity: .7;
}
.chip-on {
  background: #4f46e5;
  color: #fff;
  font-weight: 600;
}
.chip-del {
  background: #fef2f2;
  color: #ef4444;
}

/* ===== 选科室入口 ===== */
.pick-loc {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border: 2rpx dashed #d0d9f0;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #4f46e5;
  font-weight: 500;
}
.pick-loc:active {
  background: #eef2ff;
}

/* ===== 底部按钮 ===== */
.bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: max(20rpx, env(safe-area-inset-bottom));
  background: #fff;
  border-top: 2rpx solid #e8ecf1;
}
.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(79,70,229,0.3);
}
.btn-primary[disabled] { opacity: 0.5; }

/* ===== 弹窗 ===== */
.modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.modal-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
}
.modal-sheet {
  position: relative;
  width: 100%;
  max-width: 750rpx;
  max-height: 60vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}
.modal-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f1f5f9;
  flex-shrink: 0;
}
.modal-tt {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  flex: 1;
}
.modal-close {
  font-size: 28rpx;
  color: #94a3b8;
  padding: 8rpx;
}
.modal-list {
  overflow-y: auto;
  padding: 0 30rpx;
  -webkit-overflow-scrolling: touch;
}
.modal-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 0;
  border-bottom: 2rpx solid #f8fafc;
}
.modal-item:last-child { border-bottom: none; }
.modal-item:active { opacity: .7; }
.modal-item-t {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}
.modal-item-d {
  font-size: 24rpx;
  color: #64748b;
}
