/* 加载 */
.loading-wrap { display: flex; flex-direction: column; align-items: center; padding: 200rpx 0; color: #94a3b8; font-size: 28rpx; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 6rpx solid #e2e8f0; border-top-color: #6366f1; border-radius: 50%; animation: spin .8s linear infinite; margin-bottom: 20rpx; }
@keyframes spin { to { transform: rotate(360deg); } }

/* 考试列表 */
.exam-list-page { padding: 30rpx; }
.page-header { margin-bottom: 30rpx; }
.page-title { font-size: 40rpx; font-weight: 700; color: #1e293b; }
.page-desc { font-size: 26rpx; color: #94a3b8; margin-top: 8rpx; display: block; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; color: #94a3b8; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.exam-cards { display: flex; flex-direction: column; gap: 20rpx; }
.exam-card { background: #fff; border-radius: 16rpx; padding: 30rpx; display: flex; align-items: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.04); }
.exam-card-body { flex: 1; }
.exam-title { font-size: 32rpx; font-weight: 600; color: #1e293b; }
.exam-meta { font-size: 24rpx; color: #94a3b8; margin-top: 8rpx; }

/* 答题页 */
.exam-take { display: flex; flex-direction: column; height: 100vh; background: #f0f2f8; }
.progress-bar { height: 6rpx; background: #e2e8f0; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #6366f1, #818cf8); transition: width .3s; }
.exam-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 30rpx; background: #fff; border-bottom: 1rpx solid #e2e8f0; }
.q-counter { font-size: 26rpx; color: #64748b; }
.timer { font-size: 32rpx; font-weight: 700; font-variant-numeric: tabular-nums; color: #1e293b; }
.timer.warning { color: #f59e0b; }
.timer.danger { color: #ef4444; }

.q-scroll { flex: 1; padding: 20rpx 30rpx; }
.q-card { background: #fff; border-radius: 20rpx; padding: 30rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,.04); }
.q-type-badge { display: inline-flex; align-items: center; gap: 8rpx; padding: 6rpx 20rpx; border-radius: 30rpx; font-size: 24rpx; background: rgba(99,102,241,.1); color: #6366f1; margin-bottom: 20rpx; }
.q-score { opacity: .6; margin-left: 8rpx; }
.q-text { font-size: 32rpx; line-height: 1.6; color: #1e293b; margin-bottom: 28rpx; }

.options-list { display: flex; flex-direction: column; gap: 16rpx; }
.option-item { display: flex; align-items: center; gap: 16rpx; padding: 24rpx 20rpx; border: 2rpx solid #e2e8f0; border-radius: 16rpx; background: #fff; }
.option-item.selected { border-color: #6366f1; background: rgba(99,102,241,.04); }
.opt-radio { width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid #cbd5e1; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.opt-radio.multi { border-radius: 8rpx; }
.option-item.selected .opt-radio { border-color: #6366f1; background: #6366f1; }
.opt-check { color: #fff; font-size: 24rpx; font-weight: 700; }
.opt-content { display: flex; gap: 10rpx; align-items: center; }
.opt-label { font-weight: 700; color: #64748b; font-size: 28rpx; }
.opt-text { color: #1e293b; font-size: 28rpx; }

.judge-btns { display: flex; gap: 20rpx; }
.judge-btn { flex: 1; padding: 28rpx; border: 2rpx solid #e2e8f0; border-radius: 16rpx; display: flex; flex-direction: column; align-items: center; gap: 8rpx; font-size: 30rpx; font-weight: 600; background: #fff; }
.judge-btn.selected.true { border-color: #22c55e; background: rgba(34,197,94,.06); color: #22c55e; }
.judge-btn.selected.false { border-color: #ef4444; background: rgba(239,68,68,.06); color: #ef4444; }
.judge-icon { font-size: 40rpx; }

.fill-input { width: 100%; padding: 24rpx; border: 2rpx solid #e2e8f0; border-radius: 16rpx; font-size: 30rpx; background: #fff; }
.fill-input:focus { border-color: #6366f1; }

.q-nav { display: flex; gap: 16rpx; padding: 20rpx 30rpx; background: #fff; border-top: 1rpx solid #e2e8f0; }
.q-nav button { flex: 1; padding: 20rpx; border-radius: 12rpx; font-size: 28rpx; font-weight: 500; border: none; }
.btn-prev { background: #e2e8f0; color: #1e293b; }
.btn-prev.disabled { opacity: .4; }
.btn-next { background: #6366f1; color: #fff; }
.btn-submit { background: #22c55e; color: #fff; }

.dot-scroll { padding: 16rpx 30rpx; background: #fff; white-space: nowrap; }
.q-dots { display: flex; gap: 10rpx; }
.q-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #e2e8f0; flex-shrink: 0; }
.q-dot.active { background: #6366f1; transform: scale(1.4); }
.q-dot.answered { background: #22c55e; }

/* 交卷确认弹窗 */
.confirm-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); display: none; align-items: center; justify-content: center; z-index: 1000; padding: 40rpx; }
.confirm-overlay.show { display: flex; }
.confirm-dialog { background: #fff; border-radius: 24rpx; padding: 48rpx 40rpx; width: 100%; max-width: 560rpx; text-align: center; }
.confirm-title { font-size: 36rpx; font-weight: 700; color: #1e293b; display: block; margin-bottom: 16rpx; }
.confirm-desc { font-size: 28rpx; color: #64748b; display: block; margin-bottom: 32rpx; }
.confirm-btns { display: flex; gap: 16rpx; }
.confirm-btns button { flex: 1; padding: 20rpx; border-radius: 12rpx; font-size: 28rpx; border: none; }
.btn-cancel { background: #e2e8f0; color: #1e293b; }
.btn-confirm { background: #22c55e; color: #fff; }

/* 结果页 */
.result-page { display: flex; align-items: center; justify-content: center; min-height: 100vh; background: #f0f2f8; padding: 40rpx; }
.result-card { background: #fff; border-radius: 24rpx; padding: 60rpx 40rpx; text-align: center; width: 100%; max-width: 600rpx; }
.result-circle { width: 160rpx; height: 160rpx; border-radius: 50%; margin: 0 auto 24rpx; display: flex; align-items: center; justify-content: center; }
.result-circle.passed { background: rgba(34,197,94,.12); border: 8rpx solid #22c55e; }
.result-circle.failed { background: rgba(239,68,68,.12); border: 8rpx solid #ef4444; }
.result-icon { font-size: 64rpx; font-weight: 700; }
.result-circle.passed .result-icon { color: #22c55e; }
.result-circle.failed .result-icon { color: #ef4444; }
.result-title { font-size: 40rpx; font-weight: 700; color: #1e293b; display: block; margin-bottom: 16rpx; }
.result-score { font-size: 48rpx; font-weight: 700; color: #6366f1; margin-bottom: 30rpx; }
.result-detail { margin-bottom: 32rpx; }
.detail-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #e2e8f0; font-size: 28rpx; color: #1e293b; }
.btn-primary { padding: 24rpx; border-radius: 12rpx; background: #6366f1; color: #fff; font-size: 28rpx; border: none; }
